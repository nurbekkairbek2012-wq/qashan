# Шаблон окружения. Скопируй в .env и подставь свои значения:
#
#   cp .env.example .env
#
# Сам .env в git не попадает (.gitignore) — там реальные ключи.
# Этот файл коммитится, чтобы было видно, какие переменные нужны для запуска.

# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# ЧЕГО ЗДЕСЬ БЫТЬ НЕ ДОЛЖНО
#
# Префикс VITE_ означает: переменная попадает в браузерный бандл и видна всем,
# кто откроет DevTools. Это не хранилище секретов, а способ передать настройки.
#
# anon key класть можно: он и так уходит клиенту по замыслу Supabase,
# доступ к данным ограничивает RLS на стороне базы, а не секретность ключа.
#
# НИКОГДА не класть сюда:
#   · SUPABASE_SERVICE_ROLE_KEY — обходит RLS целиком, полный доступ к базе
#   · ANTHROPIC_API_KEY         — живёт только в Edge Function, на сервере
#
# Оба задаются как секреты Supabase и на клиент не попадают.
# ---------------------------------------------------------------------------
